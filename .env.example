# =============================================================================
# DocuQuery Environment Configuration
# Copy this file to .env and adjust values as needed
# =============================================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=docuquery
POSTGRES_PASSWORD=docuquery_dev_password
POSTGRES_DB=docuquery
DATABASE_URL=postgres://docuquery:docuquery_dev_password@localhost:5433/docuquery?sslmode=disable

# --- Go Backend ---
BACKEND_PORT=8080
BACKEND_HOST=0.0.0.0
EMBEDDING_SERVICE_URL=http://localhost:8001
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b
MAX_UPLOAD_SIZE_MB=50
LOG_LEVEL=debug

# --- Embedding Service (Python) ---
EMBEDDING_PORT=8001
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# --- Ollama ---
OLLAMA_HOST=0.0.0.0:11434
